NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/telled-crm?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@telled.com
EMAIL_FROM_NAME=Telled CRM

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
